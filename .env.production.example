# === REQUIRED ===
DATABASE_URL=postgresql+asyncpg://user:password@host:5432/trustcapture_db
SECRET_KEY=generate-a-random-64-character-string-here
JWT_SECRET_KEY=generate-another-random-64-character-string-here
CORS_ORIGINS=https://your-frontend-domain.onrender.com

# Port (Render sets this automatically)
PORT=8000
WORKERS=2

# Storage (use mock for testing, set AWS keys for production)
USE_MOCK_STORAGE=true
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# S3_BUCKET_NAME=

# === OPTIONAL - Geocoding ===
# Without this, Nominatim (OpenStreetMap) is used as fallback - fine for testing
# GOOGLE_MAPS_API_KEY=

# === OPTIONAL - SMS (needed for vendor OTP login) ===
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_PHONE_NUMBER=

# === OPTIONAL - Payments ===
# STRIPE_SECRET_KEY=
# RAZORPAY_KEY_ID=
# RAZORPAY_KEY_SECRET=

# === OPTIONAL - Email ===
# SENDGRID_API_KEY=
# SENDGRID_FROM_EMAIL=
